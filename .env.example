# Environment Configuration
ENVIRONMENT=production

# LLM Configuration (Required)
LLM_PROVIDER=google
LLM_MODEL=gemini-2.5-flash-lite
LLM_API_KEY=your_google_api_key_here
LLM_BASE_URL=
LLM_MAX_TOKENS=500
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.9
LLM_FREQUENCY_PENALTY=0.0
LLM_PRESENCE_PENALTY=0.0
LLM_TIMEOUT=60.0
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=1.0

# Timer Configuration
TIME_LIMITS=1,2,3,5,10,15,30
CUTOFF_STRATEGY=immediate
GRACE_PERIOD=0.1
TIMER_PRECISION=0.01
ENABLE_PREEMPTIVE_CUTOFF=true

# Task Configuration
TASK_TYPES=reasoning,creative,qa
DYNAMIC_PROMPT_GENERATION=false
PROMPT_CACHE_SIZE=100
ENABLE_PROMPT_VALIDATION=true

# Evaluation Configuration
ENABLE_METRICS_COLLECTION=true
METRICS=completion_rate,time_to_cutoff,output_length,quality_score
QUALITY_SCORING_ENABLED=true
ENABLE_STATISTICAL_ANALYSIS=true
CONFIDENCE_INTERVAL=0.95
SAMPLE_SIZE=100
BENCHMARK_COMPARISON_ENABLED=false

# Resource Configuration
MAX_CONCURRENT_REQUESTS=5
REQUEST_RATE_LIMIT=10.0
CPU_AFFINITY=
MEMORY_LIMIT=
ENABLE_GPU_ACCELERATION=false
GPU_MEMORY_FRACTION=0.8
ENABLE_MEMORY_OPTIMIZATION=true

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=outputs/logs.txt
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_ROTATION=daily
MAX_LOG_SIZE=100
BACKUP_COUNT=7
ENABLE_FILE_LOGGING=true
ENABLE_CONSOLE_LOGGING=true
INCLUDE_STACK_TRACES=false

# Output Configuration
OUTPUT_DIRECTORY=outputs
RESPONSE_FILE=responses.json
METRICS_FILE=metrics.csv
ENABLE_JSON_OUTPUT=true
ENABLE_CSV_OUTPUT=true
COMPRESSION_LEVEL=0
BACKUP_STRATEGY=timestamp
MAX_STORAGE_SIZE=1000
CLEANUP_AGE_DAYS=30

# Feature Flags
ENABLE_EARLY_CUTOFF=true
ENABLE_PARTIAL_RESPONSE_SAVING=true
ENABLE_PROMPT_ENHANCEMENT=false
ENABLE_CACHING=true
ENABLE_RATE_LIMITING=true
ENABLE_THROTTLING=true
ENABLE_ERROR_HANDLING=true
ENABLE_RETRY_LOGIC=true
ENABLE_PERFORMANCE_TRACKING=true

# Security Configuration
API_KEY_ROTATION_ENABLED=false
API_KEY_ROTATION_INTERVAL=30
DATA_ENCRYPTION_ENABLED=false
ENCRYPTION_ALGORITHM=AES-256
AUDIT_LOGGING_ENABLED=false
AUDIT_LOG_PATH=audit.log
DATA_RETENTION_PERIOD=90
ENABLE_INPUT_VALIDATION=true
SANITIZE_OUTPUT=false
